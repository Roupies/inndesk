DATABASE_URL=postgresql://user:password@localhost:5432/inndesk
JWT_SECRET=change-this-to-a-long-random-secret

# Docker only — password for the inndesk PostgreSQL user
POSTGRES_PASSWORD=change-this-to-a-strong-password
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=8

# Hotel settings for invoices
HOTEL_NAME=Hôtel de la Paix
HOTEL_ADDRESS=12 Rue de Rivoli, 75001 Paris
HOTEL_SIRET=123 456 789 00012
HOTEL_EMAIL=contact@hotel-de-la-paix.fr
HOTEL_PHONE=+33 1 42 00 00 00

# Email settings (get your API key from https://resend.com)
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=factures@hotel-de-la-paix.fr